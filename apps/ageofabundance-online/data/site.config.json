              "meta": {
                "order": 2
              }
            },
            {
              "id": "milestone-3",
              "type": "entry",
              "subject": {
                "title": "Platform",
                "color": "#06b6d4"
              },
              "content": {
                "body": "Full no-code platform with visual editor and deployment pipeline"
              },
              "meta": {
                "order": 3
              }
            }
          ]
        },
        {
          "id": "cta",
          "type": "section",
          "name": "cta",
          "subject": {
            "title": "Join the Transform"
          },
          "content": {
            "body": "Be part of the age of abundance. ageofabundance.online is just getting started."
          },
          "display": {
            "layout": "centered-text"
          }
        }
      ]
    }
