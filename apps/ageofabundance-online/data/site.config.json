              },
              "meta": {
                "order": 1
              }
            },
            {
              "id": "milestone-2",
              "type": "entry",
              "subject": {
                "title": "Generate",
                "color": "#ec4899"
              },
              "content": {
                "body": "AI-powered content generation and page building from prompts"
