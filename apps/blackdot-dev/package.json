{
  "name": "@dds/blackdot-dev",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "prepare": "husky install",
    "prebuild": "npm run generate-registry && npm run generate-routes-registry",
    "build": "NEXT_TELEMETRY_DISABLED=1 next build",
    "predev": "npm run generate-routes-registry",
    "dev": "NEXT_TELEMETRY_DISABLED=1 next dev",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "validate": "npm run typecheck && npm run build",
    "start": "NEXT_TELEMETRY_DISABLED=1 next start",
    "compress-models": "node scripts/compress-models-draco-esm.mjs --all",
    "compress-models:dir": "node scripts/compress-models-draco-esm.mjs --dir",
    "generate-registry": "ts-node scripts/generate-registry.ts",
    "generate-routes-registry": "ts-node scripts/generate-routes-registry.ts",
    "generate-static-objects": "ts-node ~/.claude/dds-v3-scripts/generate-static-objects.ts",
    "migrate:roles": "ts-node ~/.claude/dds-v3-scripts/migrate-users-to-roles.ts",
    "db:push": "drizzle-kit push:pg",
    "db:pull": "drizzle-kit introspect:pg",
    "db:generate": "drizzle-kit generate:pg",
    "db:studio": "drizzle-kit studio",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
