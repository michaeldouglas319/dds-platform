              "meta": {
                "order": 2
              }
            },
            {
              "id": "milestone-3",
              "type": "entry",
              "subject": {
                "title": "Converge",
                "color": "#6366f1"
              },
              "content": {
                "body": "Ship the best experiments into Blackdot production tools"
              },
              "meta": {
                "order": 3
              }
            }
          ]
        },
        {
          "id": "cta",
          "type": "section",
          "name": "cta",
          "subject": {
            "title": "Join the Singularity"
          },
          "content": {
            "body": "Be part of the age of abundance. blackdot.space is just getting started."
          },
          "display": {
