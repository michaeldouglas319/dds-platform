{
  "app": {
    "name": "Blackdot Space",
    "label": "Space",
    "description": "Where ideas collapse into reality",
    "baseUrl": "https://blackdot.space",
    "defaultTheme": "dark"
  },
  "navigation": {
    "items": [
      {
        "label": "Home",
        "path": "/"
      },
      {
        "label": "About",
        "path": "/about"
      }
    ],
    "sticky": true
  },
  "pages": [
    {
      "id": "home",
      "path": "/",
      "meta": {
        "title": "Blackdot Space — Singularity",
        "description": "Where ideas collapse into reality"
      },
      "sections": [
        {
          "id": "intro",
          "type": "intro",
          "name": "intro",
          "subject": {
            "title": "Singularity"
          },
          "content": {
            "body": "Where ideas collapse into reality",
            "highlights": [
              "Design",
              "Research",
              "Prototype",
              "Experiment",
              "Iterate",
              "Ship"
            ]
          },
          "display": {
            "layout": "intro"
          },
          "meta": {
            "scrollTarget": "/#stats",
            "textTransition": "reveal",
            "textTransitionDuration": 1200,
            "textTransitionInterval": 4000,
            "highlightPosition": "bottom",
            "highlightPrefix": "+"
          }
        },
        {
          "id": "mission",
          "type": "section",
          "name": "mission",
          "subject": {
            "title": "Blackdot Space"
          },
          "content": {
            "body": "A space for the convergence of thought, design, and execution. Where the infinite becomes the tangible."
          },
          "display": {
            "layout": "header"
          }
        },
        {
          "id": "stats",
          "type": "section",
          "name": "stats",
          "subject": {
            "title": "By the Numbers",
            "subtitle": "Key metrics"
          },
          "content": {
            "stats": [
              {
                "label": "Experiments",
                "value": "100+"
              },
              {
                "label": "Prototypes",
                "value": "40+"
              },
              {
                "label": "Published Papers",
                "value": "12"
              },
              {
                "label": "Shipped to Prod",
                "value": "60%"
              }
            ]
          },
          "display": {
            "layout": "stats-grid"
          },
          "meta": {
            "columns": 4
          }
        },
        {
          "id": "vision",
          "type": "section",
          "name": "vision",
          "subject": {
            "title": "Our Vision"
          },
          "content": {
            "body": "The experimental arm of Blackdot — a laboratory for ideas too ambitious for roadmaps and too important to ignore."
          },
          "display": {
            "layout": "text-only"
          }
        },
        {
          "id": "features",
          "type": "section",
          "name": "features",
          "subject": {
            "title": "What We Offer",
