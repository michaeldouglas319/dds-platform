                }
              },
              {
                "feature": "Direct Research",
                "values": {
                  "observe": false,
                  "participate": false,
                  "sponsor": true
                }
              },
              {
                "feature": "IP Licensing",
                "values": {
                  "observe": false,
                  "participate": false,
                  "sponsor": true
                }
              }
            ]
          },
          "display": {
            "layout": "feature-matrix"
          }
        },
        {
          "id": "roadmap",
