{
  "app": {
    "name": "Age of Abundance",
    "description": "The corporate home of Age of Abundance",
    "baseUrl": "https://ageofabundance.site",
    "defaultTheme": "dark"
  },
  "navigation": {
    "items": [
      {
        "label": "Home",
        "path": "/"
      },
      {
        "label": "About",
        "path": "/about"
      }
    ],
    "sticky": true
  },
  "pages": [
    {
      "id": "home",
      "path": "/",
      "meta": {
        "title": "Age of Abundance — Foundation",
        "description": "The corporate home of Age of Abundance"
      },
      "sections": [
        {
          "id": "intro",
          "type": "intro",
          "name": "intro",
          "subject": {
            "title": "Foundation"
          },
          "content": {
            "body": "The corporate home of Age of Abundance",
            "highlights": [
              "Mission",
              "Vision",
              "Team",
              "Values",
              "Impact",
              "Future"
            ]
          },
          "display": {
            "layout": "intro"
          },
          "meta": {
            "scrollTarget": "/#stats",
            "textTransition": "reveal",
            "textTransitionDuration": 1200,
            "textTransitionInterval": 4000,
            "highlightPosition": "bottom",
            "highlightPrefix": "+"
          }
        },
        {
          "id": "mission",
          "type": "section",
          "name": "mission",
          "subject": {
            "title": "Age of Abundance"
          },
          "content": {
            "body": "We are building the infrastructure for a world where scarcity is a choice, not a constraint."
          },
          "display": {
            "layout": "header"
          }
        },
        {
          "id": "stats",
          "type": "section",
          "name": "stats",
          "subject": {
            "title": "By the Numbers",
            "subtitle": "Key metrics"
          },
          "content": {
            "stats": [
              {
                "label": "Ventures",
                "value": "14"
              },
              {
                "label": "Domains",
                "value": "14"
              },
              {
                "label": "Team Size",
                "value": "50+"
              },
              {
                "label": "Founded",
                "value": "2025"
              }
            ]
          },
          "display": {
            "layout": "stats-grid"
          },
          "meta": {
            "columns": 4
          }
        },
        {
          "id": "vision",
          "type": "section",
          "name": "vision",
          "subject": {
            "title": "Our Vision"
          },
          "content": {
            "body": "Age of Abundance is a holding company and innovation lab dedicated to proving that abundance-oriented businesses outperform scarcity-driven ones."
          },
          "display": {
            "layout": "text-only"
          }
        },
        {
          "id": "features",
          "type": "section",
          "name": "features",
          "subject": {
            "title": "What We Offer",
            "subtitle": "Choose your path"
          },
          "content": {
            "columns": [
              {
                "name": "partner",
                "label": "Partner"
              },
              {
                "name": "investor",
                "label": "Investor",
                "highlight": true
              },
              {
                "name": "acquirer",
                "label": "Acquirer"
              }
            ],
            "rows": [
              {
                "feature": "Portfolio Access",
                "values": {
                  "partner": true,
                  "investor": true,
                  "acquirer": true
                }
              },
              {
                "feature": "Revenue Data",
                "values": {
                  "partner": false,
                  "investor": true,
                  "acquirer": true
                }
              },
              {
                "feature": "Due Diligence",
                "values": {
                  "partner": false,
                  "investor": false,
                  "acquirer": true
                }
              },
              {
                "feature": "Board Seat",
                "values": {
                  "partner": false,
                  "investor": true,
                  "acquirer": false
                }
              },
              {
                "feature": "Acquisition Terms",
                "values": {
                  "partner": false,
                  "investor": false,
                  "acquirer": true
                }
              }
            ]
          },
          "display": {
            "layout": "feature-matrix"
          }
        },
        {
          "id": "roadmap",
          "type": "section",
          "name": "roadmap",
          "subject": {
            "title": "Roadmap"
          },
          "display": {
            "layout": "timeline"
          },
          "children": [
            {
              "id": "milestone-1",
              "type": "entry",
              "subject": {
                "title": "Establish",
                "color": "#3b82f6"
              },
              "content": {
                "body": "Launch 14 domain ventures across commerce, art, tech, and community"
              },
              "meta": {
                "order": 1
              }
            },
            {
              "id": "milestone-2",
              "type": "entry",
              "subject": {
                "title": "Prove",
                "color": "#22c55e"
              },
              "content": {
                "body": "Demonstrate abundance model viability with revenue and user growth"
              },
              "meta": {
                "order": 2
              }
            },
            {
              "id": "milestone-3",
              "type": "entry",
              "subject": {
                "title": "Expand",
                "color": "#f59e0b"
              },
              "content": {
                "body": "License the model, spin out ventures, and fund abundance startups"
              },
              "meta": {
                "order": 3
              }
            }
          ]
        },
        {
          "id": "cta",
          "type": "section",
          "name": "cta",
          "subject": {
            "title": "Join the Foundation"
          },
          "content": {
            "body": "Be part of the age of abundance. ageofabundance.site is just getting started."
          },
          "display": {
            "layout": "centered-text"
          }
        }
      ]
    }
  ]
}
