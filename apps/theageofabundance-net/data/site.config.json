            { "id": "r2", "type": "entry", "subject": { "title": "Mesh", "color": "#6366f1" }, "content": { "body": "Service mesh with automatic discovery, auth, and rate limiting." }, "meta": { "order": 2 } },
            { "id": "r3", "type": "entry", "subject": { "title": "Federate", "color": "#10b981" }, "content": { "body": "Open federation protocol for third-party abundance services." }, "meta": { "order": 3 } }
          ]
        },
