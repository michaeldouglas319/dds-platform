              { "feature": "Media API", "description": "Image processing, CDN", "values": { "service": "art", "protocol": "REST", "status": "Live" } },
              { "feature": "Analytics API", "description": "Cross-domain analytics", "values": { "service": "all", "protocol": "Streaming", "status": "Beta" } },
              { "feature": "AI Gateway", "description": "Model routing, inference", "values": { "service": "ai", "protocol": "REST + WS", "status": "Alpha" } }
            ]
          },
          "display": { "layout": "feature-matrix" }
        },
        {
          "id": "roadmap",
          "type": "section",
          "name": "roadmap",
          "subject": { "title": "Network Roadmap" },
          "display": { "layout": "timeline" },
