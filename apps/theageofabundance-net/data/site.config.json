              { "label": "Avg Response", "value": "<50ms" }
            ]
          },
          "display": { "layout": "stats-grid" },
          "meta": { "columns": 4 }
        },
        {
          "id": "services",
          "type": "section",
          "name": "services",
          "subject": { "title": "Connected Services", "subtitle": "The abundance mesh" },
          "content": {
            "columns": [
