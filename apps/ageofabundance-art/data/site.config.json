{
  "app": {
    "name": "Age of Abundance — Art",
    "label": "Art",
    "description": "Where art meets infinite possibility",
    "baseUrl": "https://ageofabundance.art",
    "defaultTheme": "dark"
  },
  "navigation": {
    "items": [
      {
        "label": "Home",
        "path": "/"
      },
      {
        "label": "About",
        "path": "/about"
      }
    ],
    "sticky": true
  },
  "pages": [
    {
      "id": "home",
      "path": "/",
      "meta": {
        "title": "Age of Abundance — Art — Creation",
        "description": "Where art meets infinite possibility"
      },
      "sections": [
        {
          "id": "intro",
          "type": "intro",
          "name": "intro",
          "subject": {
            "title": "Creation"
          },
          "content": {
            "body": "Where art meets infinite possibility",
            "highlights": [
              "Visual",
              "Generative",
              "Interactive",
              "Immersive",
              "Collaborative",
              "Timeless"
            ]
          },
          "display": {
            "layout": "intro"
          },
          "meta": {
            "scrollTarget": "/#stats",
            "textTransition": "reveal",
            "textTransitionDuration": 1200,
            "textTransitionInterval": 4000,
            "highlightPosition": "bottom",
            "highlightPrefix": "+"
          }
        },
        {
          "id": "mission",
          "type": "section",
          "name": "mission",
          "subject": {
            "title": "Age of Abundance — Art"
          },
          "content": {
            "body": "Art is the language of abundance. Every creation expands the boundaries of what we thought possible."
          },
          "display": {
            "layout": "header"
          }
        },
        {
          "id": "stats",
          "type": "section",
          "name": "stats",
          "subject": {
            "title": "By the Numbers",
            "subtitle": "Key metrics"
          },
          "content": {
            "stats": [
              {
                "label": "Artists Featured",
                "value": "300+"
              },
              {
                "label": "Works Exhibited",
                "value": "2,000+"
              },
              {
                "label": "Generative Collections",
                "value": "45"
              },
              {
                "label": "Gallery Views",
                "value": "1M+"
              }
            ]
          },
          "display": {
            "layout": "stats-grid"
          },
          "meta": {
            "columns": 4
          }
        },
        {
          "id": "vision",
          "type": "section",
          "name": "vision",
          "subject": {
            "title": "Our Vision"
          },
          "content": {
            "body": "We are building the definitive platform for art in the age of AI — where human creativity and machine capability merge to produce work that neither could alone."
          },
          "display": {
            "layout": "text-only"
          }
        },
        {
          "id": "features",
          "type": "section",
          "name": "features",
          "subject": {
            "title": "What We Offer",
            "subtitle": "Choose your path"
          },
          "content": {
            "columns": [
              {
                "name": "viewer",
                "label": "Viewer"
              },
              {
                "name": "collector",
                "label": "Collector",
                "highlight": true
              },
              {
                "name": "artist",
                "label": "Artist"
              }
            ],
            "rows": [
              {
                "feature": "Browse Gallery",
                "values": {
                  "viewer": true,
                  "collector": true,
                  "artist": true
                }
              },
              {
                "feature": "Acquire Works",
                "values": {
                  "viewer": false,
                  "collector": true,
                  "artist": false
                }
              },
              {
                "feature": "Submit Work",
                "values": {
                  "viewer": false,
                  "collector": false,
                  "artist": true
                }
              },
              {
                "feature": "Provenance Tracking",
                "values": {
                  "viewer": false,
                  "collector": true,
                  "artist": true
                }
              },
              {
                "feature": "Commission Access",
                "values": {
                  "viewer": false,
                  "collector": true,
                  "artist": true
                }
              }
            ]
          },
          "display": {
            "layout": "feature-matrix"
          }
        },
        {
          "id": "roadmap",
          "type": "section",
          "name": "roadmap",
          "subject": {
            "title": "Roadmap"
          },
          "display": {
            "layout": "timeline"
          },
          "children": [
            {
              "id": "milestone-1",
              "type": "entry",
              "subject": {
                "title": "Gallery",
                "color": "#ec4899"
              },
              "content": {
                "body": "Launch curated digital gallery with human + AI collaborative works"
              },
              "meta": {
                "order": 1
              }
            },
            {
              "id": "milestone-2",
              "type": "entry",
              "subject": {
                "title": "Marketplace",
                "color": "#f59e0b"
              },
              "content": {
                "body": "Enable direct artist-to-collector transactions with provenance"
              },
              "meta": {
                "order": 2
              }
            },
            {
              "id": "milestone-3",
              "type": "entry",
              "subject": {
                "title": "Studio",
                "color": "#8b5cf6"
              },
              "content": {
                "body": "Generative art tools for artists to collaborate with AI in real-time"
              },
              "meta": {
                "order": 3
              }
            }
          ]
        },
        {
          "id": "cta",
          "type": "section",
          "name": "cta",
          "subject": {
            "title": "Join the Creation"
          },
          "content": {
            "body": "Be part of the age of abundance. ageofabundance.art is just getting started."
          },
          "display": {
            "layout": "centered-text"
          }
        }
      ]
    }
  ]
}
